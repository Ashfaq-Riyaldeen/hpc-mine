        <mxCell id="2" value="Hybrid MPI+OpenMP — Two-Level Parallelism" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=16;fontColor=#d45f00;" vertex="1" parent="1">
          <mxGeometry x="200" y="15" width="650" height="35" as="geometry" />
