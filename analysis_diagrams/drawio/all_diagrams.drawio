        <mxCell id="51" value="&lt;b&gt;MPI_Reduce&lt;/b&gt;&lt;br&gt;Each rank contributes&lt;br&gt;partial MAE sum.&lt;br&gt;Rank 0 receives&lt;br&gt;global total.&lt;br&gt;op = MPI_SUM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="850" y="405" width="160" height="130" as="geometry" />
