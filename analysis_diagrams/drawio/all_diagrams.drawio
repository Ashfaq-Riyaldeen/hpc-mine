          <mxGeometry x="30" y="158" width="90" height="44" as="geometry" />
        </mxCell>
        <mxCell id="fk" value="FORK" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="155" y="152" width="74" height="56" as="geometry" />
        </mxCell>
        <mxCell id="t0" value="Thread 0  ·  user rows 0–249" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="270" y="100" width="360" height="34" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="Thread 1  ·  user rows 250–499" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe6cb;strokeColor=#82b366;fontSize=11;arcSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="270" y="142" width="360" height="34" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="Thread 2  ·  user rows 500–749" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bfddb9;strokeColor=#82b366;fontSize=11;arcSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="270" y="184" width="360" height="34" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="Thread 3  ·  user rows 750–999" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#aed4a6;strokeColor=#82b366;fontSize=11;arcSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="270" y="226" width="360" height="34" as="geometry" />
        </mxCell>
        <mxCell id="jn" value="JOIN" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="670" y="152" width="74" height="56" as="geometry" />
        </mxCell>
        <mxCell id="mr" value="Master&#10;Thread" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d7a2d;strokeColor=#1e5320;fontColor=#ffffff;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="780" y="158" width="90" height="44" as="geometry" />
        </mxCell>
        <mxCell id="a_ml_fk" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#2d7a2d;" edge="1" source="ml" target="fk" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_fk_t0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="fk" target="t0" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_fk_t1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="fk" target="t1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_fk_t2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="fk" target="t2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_fk_t3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="fk" target="t3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_t0_jn" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="t0" target="jn" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_t1_jn" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="t1" target="jn" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_t2_jn" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="t2" target="jn" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_t3_jn" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="t3" target="jn" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_jn_mr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#2d7a2d;" edge="1" source="jn" target="mr" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bar" value="Implicit barrier:&#10;all threads finish&#10;before master resumes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="228" width="160" height="48" as="geometry" />
        </mxCell>
        <mxCell id="sm" value="SHARED MEMORY (one address space)   —   ratings[ ]   ·   user_mean[ ]   ·   sim_matrix[ ]   ·   predictions[ ]   (no data copying)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=2;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="300" width="840" height="34" as="geometry" />
        </mxCell>
        <mxCell id="ch" value="Key OpenMP techniques used" style="text;html=1;align=left;fontStyle=1;fontSize=11;fontColor=#2d7a2d;" vertex="1" parent="1">
          <mxGeometry x="30" y="350" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="schedule(dynamic,4) — Phase 3&#10;Triangular loop is unbalanced (row 0 ≈ 999 calls, last row ≈ 0). Threads pull chunks on demand to stay busy." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="374" width="270" height="84" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="Race-free writes&#10;Each thread owns disjoint rows. SIM(u,v) and its mirror SIM(v,u) are written by the same thread — no locks needed." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="315" y="374" width="270" height="84" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="Private buffer + reduction&#10;Phase 4: each thread malloc's its own nbrs[]. Phase 5: reduction(+:err) gives private partial sums merged at the barrier." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="374" width="270" height="84" as="geometry" />
        </mxCell>
        <mxCell id="ft" value="Timing: omp_get_wtime() (wall-clock).   Thread count set by OMP_NUM_THREADS.   Phases 2–5 are parallel; Phase 1 (RNG) stays serial." style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="30" y="470" width="840" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page3" name="3. Pthreads">
    <mxGraphModel dx="1000" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="610" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ttl" value="POSIX Threads — Explicit Thread Management" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=16;fontColor=#b06a00;" vertex="1" parent="1">
          <mxGeometry x="150" y="18" width="600" height="26" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="Same shared memory as OpenMP, but the program creates, partitions and joins every thread by hand" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="150" y="42" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="mn" value="main()  —  run_parallel(fn) per phase" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="320" y="78" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="crl" value="pthread_create() ×N" style="text;html=1;align=center;fontSize=10;fontColor=#b06a00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="138" width="180" height="18" as="geometry" />
        </mxCell>
        <mxCell id="t0" value="Thread 0&#10;work_range → rows 0–249" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;arcSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="170" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="Thread 1&#10;work_range → rows 250–499" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b3;strokeColor=#d6b656;fontSize=10;arcSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="290" y="170" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="Thread 2&#10;work_range → rows 500–749" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd699;strokeColor=#d6b656;fontSize=10;arcSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="500" y="170" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="Thread 3&#10;work_range → rows 750–999" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcc80;strokeColor=#d6b656;fontSize=10;arcSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="710" y="170" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#d6b656;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="mn" target="t0" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c1e" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#d6b656;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="mn" target="t1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c2e" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#d6b656;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="mn" target="t2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3e" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#d6b656;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="mn" target="t3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="barrier" value="pthread_join on all threads  →  PHASE BARRIER (next phase cannot start until every thread returns)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="252" width="810" height="34" as="geometry" />
        </mxCell>
        <mxCell id="j0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#d6b656;exitX=0.5;exitY=1;entryX=0.1;entryY=0;" edge="1" source="t0" target="barrier" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="j1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#d6b656;exitX=0.5;exitY=1;entryX=0.37;entryY=0;" edge="1" source="t1" target="barrier" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="j2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#d6b656;exitX=0.5;exitY=1;entryX=0.63;entryY=0;" edge="1" source="t2" target="barrier" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="j3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#d6b656;exitX=0.5;exitY=1;entryX=0.9;entryY=0;" edge="1" source="t3" target="barrier" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rep" value="↻ create / join cycle repeats for each parallel phase:  Phase 2 user means  →  Phase 3 similarity  →  Phase 4 predictions" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#b06a00;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="294" width="810" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ch" value="Key Pthreads techniques used" style="text;html=1;align=left;fontStyle=1;fontSize=11;fontColor=#b06a00;" vertex="1" parent="1">
          <mxGeometry x="30" y="330" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="Manual partitioning&#10;work_range() gives each thread a contiguous [start,end) row slice via ceiling division — covers all N rows, no overlap." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="354" width="270" height="86" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="ThreadArgs struct&#10;Each thread is passed only {tid, nthreads} and derives its own work — thread functions stay self-contained." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="315" y="354" width="270" height="86" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="Lock-free by design&#10;Disjoint row ranges + private nbrs[] per thread mean no mutex anywhere. join() is the only synchronisation point." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="354" width="270" height="86" as="geometry" />
        </mxCell>
        <mxCell id="ft" value="vs OpenMP: identical result and shared-memory model, but the developer writes the create / partition / join logic explicitly instead of one #pragma." style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="30" y="452" width="840" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page4" name="4. MPI">
    <mxGraphModel dx="1000" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ttl" value="MPI — Distributed-Memory Message Passing" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=16;fontColor=#23527c;" vertex="1" parent="1">
          <mxGeometry x="150" y="16" width="600" height="26" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="Each rank is a separate process with its OWN memory — data is shared only through explicit collectives" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="150" y="40" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="r0" value="Rank 0  (also prints results)" style="swimlane;startSize=24;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="72" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="r0a" value="Private memory:&#10;ratings[ ] · sim_matrix[ ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef3fb;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="r0">
          <mxGeometry x="20" y="34" width="220" height="42" as="geometry" />
        </mxCell>
        <mxCell id="r0b" value="Computes SIM rows 0–333" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#23527c;fontColor=#ffffff;fontSize=10;verticalAlign=middle;" vertex="1" parent="r0">
          <mxGeometry x="20" y="86" width="220" height="42" as="geometry" />
        </mxCell>
        <mxCell id="r1" value="Rank 1" style="swimlane;startSize=24;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="320" y="72" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="r1a" value="Private memory:&#10;ratings[ ] · sim_matrix[ ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef3fb;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="r1">
          <mxGeometry x="20" y="34" width="220" height="42" as="geometry" />
        </mxCell>
        <mxCell id="r1b" value="Computes SIM rows 334–666" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#23527c;fontColor=#ffffff;fontSize=10;verticalAlign=middle;" vertex="1" parent="r1">
          <mxGeometry x="20" y="86" width="220" height="42" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="Rank 2" style="swimlane;startSize=24;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="600" y="72" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="r2a" value="Private memory:&#10;ratings[ ] · sim_matrix[ ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef3fb;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;" vertex="1" parent="r2">
          <mxGeometry x="20" y="34" width="220" height="42" as="geometry" />
        </mxCell>
        <mxCell id="r2b" value="Computes SIM rows 667–999" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#23527c;fontColor=#ffffff;fontSize=10;verticalAlign=middle;" vertex="1" parent="r2">
          <mxGeometry x="20" y="86" width="220" height="42" as="geometry" />
        </mxCell>
        <mxCell id="agv" value="MPI_Allgatherv  —  every rank sends its row block, every rank receives the COMPLETE N×N similarity matrix" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="266" width="820" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ag0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;startFill=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=0.5;exitY=1;entryX=0.17;entryY=0;" edge="1" source="r0" target="agv" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;startFill=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="r1" target="agv" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ag2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;startFill=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#82b366;exitX=0.5;exitY=1;entryX=0.83;entryY=0;" edge="1" source="r2" target="agv" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pred" value="Phase 4 Predictions — fully local on each rank (no communication: the full matrix is already present everywhere)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="324" width="820" height="32" as="geometry" />
        </mxCell>
        <mxCell id="red" value="MPI_Reduce(SUM) → Rank 0  —  partial test-set error from each rank summed to one global MAE / RMSE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="372" width="820" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ch" value="Key MPI techniques used" style="text;html=1;align=left;fontStyle=1;fontSize=11;fontColor=#23527c;" vertex="1" parent="1">
          <mxGeometry x="30" y="426" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="Same seed, no broadcast&#10;Every rank runs srand(SEED) and the same rand() sequence → identical data, so the ratings matrix is never sent." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="450" width="270" height="92" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="Row partitioning&#10;get_range() splits the N user rows across ranks by ceiling division. recvcounts[]/displs[] describe each rank's block for the gather." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="315" y="450" width="270" height="92" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="Barriers for timing&#10;MPI_Barrier brackets each timed phase so rank 0's clock captures the true wall-clock cost including load imbalance." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="450" width="270" height="92" as="geometry" />
        </mxCell>
        <mxCell id="ft" value="Launch: mpirun -np P ./mpi_rec   ·   timer: MPI_Wtime()   ·   scales across multiple machines, unlike OpenMP/Pthreads" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="30" y="552" width="840" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page5" name="5. CUDA">
    <mxGraphModel dx="1000" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="660" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ttl" value="CUDA — GPU Massively-Parallel Computing" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=16;fontColor=#7d2fa6;" vertex="1" parent="1">
          <mxGeometry x="150" y="14" width="600" height="26" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="Thousands of lightweight threads — one thread per (u,v) pair or per (user,item) cell" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="150" y="38" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="mhl" value="GPU Memory Hierarchy&#10;(fast → slow)" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#7d2fa6;" vertex="1" parent="1">
          <mxGeometry x="30" y="66" width="210" height="32" as="geometry" />
        </mxCell>
        <mxCell id="reg" value="Registers (per thread, &lt;1 cycle)&#10;scalars · top_sim[20] · top_rat[20]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7d2fa6;strokeColor=#54007a;fontColor=#ffffff;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="104" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="shm" value="Shared memory (per block, ~1 cycle)&#10;not used — kernels are independent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a25fc4;strokeColor=#54007a;fontColor=#ffffff;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="158" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="gbl" value="Global / DRAM (~500 cycles)&#10;d_ratings · d_user_mean · d_sim · d_pred" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cBA3dd;strokeColor=#54007a;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="212" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="hst" value="Host / CPU RAM (PCIe ~12 GB/s)&#10;h_ratings · h_sim · h_predictions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede0f4;strokeColor=#7d2fa6;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="30" y="266" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="coal" value="Threads in a warp (32) execute the same instruction (SIMT). Adjacent threads read adjacent memory → coalesced access." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=9;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="324" width="210" height="84" as="geometry" />
        </mxCell>
        <mxCell id="host1" value="HOST (CPU) — Phase 1: generate data (same SEED as serial)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede0f4;strokeColor=#7d2fa6;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="290" y="66" width="580" height="36" as="geometry" />
        </mxCell>
        <mxCell id="gpu" value="GPU DEVICE" style="swimlane;startSize=24;whiteSpace=wrap;html=1;fillColor=#f7f0fb;strokeColor=#7d2fa6;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="290" y="150" width="580" height="306" as="geometry" />
        </mxCell>
        <mxCell id="g_grid" value="GRID — ⌈1000/16⌉² = 63×63 thread blocks, scheduled across the GPU's SMs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d3f0;strokeColor=#7d2fa6;fontSize=10;verticalAlign=middle;" vertex="1" parent="gpu">
          <mxGeometry x="16" y="34" width="548" height="34" as="geometry" />
        </mxCell>
        <mxCell id="g_block" value="BLOCK = 16×16 = 256 threads   ·   thread (u,v) = blockIdx·blockDim + threadIdx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4b8e6;strokeColor=#7d2fa6;fontSize=10;verticalAlign=middle;" vertex="1" parent="gpu">
          <mxGeometry x="16" y="76" width="548" height="34" as="geometry" />
        </mxCell>
        <mxCell id="k1" value="① kernel_user_means&#10;&#10;1-D grid&#10;1 thread = 1 user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede0f4;strokeColor=#7d2fa6;fontSize=10;verticalAlign=middle;spacing=4;" vertex="1" parent="gpu">
          <mxGeometry x="16" y="126" width="168" height="150" as="geometry" />
        </mxCell>
        <mxCell id="k2" value="② kernel_similarity&#10;&#10;2-D grid&#10;1 thread = 1 (u,v) pair&#10;upper triangle; writes&#10;SIM(u,v) and SIM(v,u)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4b8e6;strokeColor=#7d2fa6;fontSize=10;verticalAlign=middle;spacing=4;" vertex="1" parent="gpu">
          <mxGeometry x="206" y="126" width="168" height="150" as="geometry" />
        </mxCell>
        <mxCell id="k3" value="③ kernel_predictions&#10;&#10;2-D grid&#10;1 thread = 1 (user,item)&#10;in-register TOP-K=20&#10;min-heap selection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a25fc4;strokeColor=#54007a;fontColor=#ffffff;fontSize=10;verticalAlign=middle;spacing=4;" vertex="1" parent="gpu">
          <mxGeometry x="396" y="126" width="168" height="150" as="geometry" />
        </mxCell>
        <mxCell id="k12" value="sync" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#7d2fa6;fontSize=9;fontColor=#7d2fa6;" edge="1" source="k1" target="k2" parent="gpu"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="k23" value="sync" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#7d2fa6;fontSize=9;fontColor=#7d2fa6;" edge="1" source="k2" target="k3" parent="gpu"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="host2" value="HOST (CPU) — Phase 5: copy predictions back, compute MAE / RMSE on test set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede0f4;strokeColor=#7d2fa6;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="290" y="486" width="580" height="36" as="geometry" />
        </mxCell>
        <mxCell id="h2d" value="cudaMemcpy  Host → Device  (ratings)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#7d2fa6;fontSize=9;fontColor=#7d2fa6;verticalAlign=bottom;" edge="1" source="host1" target="gpu" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d2h" value="cudaMemcpy  Device → Host  (predictions)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#7d2fa6;dashed=1;fontSize=9;fontColor=#7d2fa6;verticalAlign=bottom;" edge="1" source="gpu" target="host2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ft" value="Kernel timing: cudaEventRecord / cudaEventSynchronize (launches are async — the CPU must wait for the GPU to finish before timing)." style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="290" y="528" width="580" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page6" name="6. Hybrid MPI+OpenMP">
    <mxGraphModel dx="1000" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ttl" value="Hybrid MPI + OpenMP — Two-Level Parallelism" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=16;fontColor=#1f6f54;" vertex="1" parent="1">
          <mxGeometry x="150" y="16" width="600" height="26" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="MPI distributes rows across nodes (coarse grain); OpenMP threads share memory inside each node (fine grain)" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="40" width="660" height="20" as="geometry" />
        </mxCell>
        <mxCell id="cl" value="CLUSTER" style="swimlane;startSize=26;whiteSpace=wrap;html=1;fillColor=#eef3fb;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="74" width="820" height="212" as="geometry" />
        </mxCell>
        <mxCell id="n0" value="Node 0  —  MPI Rank 0  (private address space)" style="swimlane;startSize=22;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;verticalAlign=top;align=center;" vertex="1" parent="cl">
          <mxGeometry x="18" y="36" width="384" height="160" as="geometry" />
        </mxCell>
        <mxCell id="n0m" value="Shared memory · MPI rows 0–499" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef3fb;strokeColor=#6c8ebf;fontSize=9;verticalAlign=middle;" vertex="1" parent="n0">
          <mxGeometry x="12" y="28" width="360" height="26" as="geometry" />
        </mxCell>
        <mxCell id="n0t0" value="OMP&#10;T0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;verticalAlign=middle;" vertex="1" parent="n0"><mxGeometry x="12" y="64" width="80" height="58" as="geometry" /></mxCell>
        <mxCell id="n0t1" value="OMP&#10;T1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe6cb;strokeColor=#82b366;fontSize=9;verticalAlign=middle;" vertex="1" parent="n0"><mxGeometry x="100" y="64" width="80" height="58" as="geometry" /></mxCell>
        <mxCell id="n0t2" value="OMP&#10;T2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bfddb9;strokeColor=#82b366;fontSize=9;verticalAlign=middle;" vertex="1" parent="n0"><mxGeometry x="188" y="64" width="80" height="58" as="geometry" /></mxCell>
        <mxCell id="n0t3" value="OMP&#10;T3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#aed4a6;strokeColor=#82b366;fontSize=9;verticalAlign=middle;" vertex="1" parent="n0"><mxGeometry x="276" y="64" width="80" height="58" as="geometry" /></mxCell>
        <mxCell id="n0lbl" value="#pragma omp parallel for (shared memory, no messages inside the node)" style="text;html=1;align=center;fontSize=9;fontColor=#2d7a2d;" vertex="1" parent="n0"><mxGeometry x="12" y="128" width="360" height="24" as="geometry" /></mxCell>
        <mxCell id="n1" value="Node 1  —  MPI Rank 1  (private address space)" style="swimlane;startSize=22;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;verticalAlign=top;align=center;" vertex="1" parent="cl">
          <mxGeometry x="418" y="36" width="384" height="160" as="geometry" />
        </mxCell>
        <mxCell id="n1m" value="Shared memory · MPI rows 500–999" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef3fb;strokeColor=#6c8ebf;fontSize=9;verticalAlign=middle;" vertex="1" parent="n1">
          <mxGeometry x="12" y="28" width="360" height="26" as="geometry" />
        </mxCell>
        <mxCell id="n1t0" value="OMP&#10;T0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;verticalAlign=middle;" vertex="1" parent="n1"><mxGeometry x="12" y="64" width="80" height="58" as="geometry" /></mxCell>
        <mxCell id="n1t1" value="OMP&#10;T1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe6cb;strokeColor=#82b366;fontSize=9;verticalAlign=middle;" vertex="1" parent="n1"><mxGeometry x="100" y="64" width="80" height="58" as="geometry" /></mxCell>
        <mxCell id="n1t2" value="OMP&#10;T2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bfddb9;strokeColor=#82b366;fontSize=9;verticalAlign=middle;" vertex="1" parent="n1"><mxGeometry x="188" y="64" width="80" height="58" as="geometry" /></mxCell>
        <mxCell id="n1t3" value="OMP&#10;T3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#aed4a6;strokeColor=#82b366;fontSize=9;verticalAlign=middle;" vertex="1" parent="n1"><mxGeometry x="276" y="64" width="80" height="58" as="geometry" /></mxCell>
        <mxCell id="n1lbl" value="#pragma omp parallel for (shared memory, no messages inside the node)" style="text;html=1;align=center;fontSize=9;fontColor=#2d7a2d;" vertex="1" parent="n1"><mxGeometry x="12" y="128" width="360" height="24" as="geometry" /></mxCell>
        <mxCell id="mpilink" value="MPI&#10;Allgatherv&#10;Reduce" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;startFill=1;endArrow=block;endFill=1;strokeWidth=2.5;strokeColor=#b85450;fontSize=9;fontColor=#b85450;fontStyle=1;" edge="1" source="n0" target="n1" parent="cl"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="lvl1" value="LEVEL 1 — MPI across nodes (coarse): P ranks own disjoint row blocks; Allgatherv assembles the matrix, Reduce sums the error." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="820" height="34" as="geometry" />
        </mxCell>
        <mxCell id="lvl2" value="LEVEL 2 — OpenMP within a node (fine): T threads split that rank's rows over shared memory, with a private nbrs[] buffer each." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="820" height="34" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="P × T total workers&#10;e.g. 2 ranks × 4 threads = 8 workers, while sending only P (not P×T) messages per collective." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="390" height="78" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="MPI_THREAD_FUNNELED&#10;Only the main thread calls MPI (outside OpenMP regions), so a lightweight thread-safety level is enough." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=top;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="470" y="390" width="390" height="78" as="geometry" />
        </mxCell>
        <mxCell id="ft" value="Launch: mpirun -np 2 env OMP_NUM_THREADS=4 ./hybrid_rec   ·   matches real clusters: many multi-core nodes on a network" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="478" width="820" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
