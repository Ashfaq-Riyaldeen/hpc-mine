        <mxCell id="42" value="Thread 1&lt;br&gt;rows 250–499" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c99d30;strokeColor=#7d5c00;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
