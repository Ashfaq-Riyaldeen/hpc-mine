        <!-- OMP Threads inside Node 1 -->
        <mxCell id="15" value="OMP Thread 0&lt;br&gt;rows 500–624" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d45f00;strokeColor=#8c3d00;fontColor=#ffffff;fontSize=9;" vertex="1" parent="14">
          <mxGeometry x="20" y="55" width="100" height="70" as="geometry" />
