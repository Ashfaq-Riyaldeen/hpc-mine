        <mxCell id="6" value="OMP Thread 1&lt;br&gt;rows 125–249" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2daa55;strokeColor=#005723;fontColor=#ffffff;fontSize=9;" vertex="1" parent="4">
          <mxGeometry x="130" y="55" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="7" value="OMP Thread 2&lt;br&gt;rows 250–374" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#52c270;strokeColor=#005723;fontColor=#ffffff;fontSize=9;" vertex="1" parent="4">
          <mxGeometry x="240" y="55" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="8" value="OMP Thread 3&lt;br&gt;rows 375–499" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a0ddad;strokeColor=#005723;fontColor=#333333;fontSize=9;" vertex="1" parent="4">
          <mxGeometry x="350" y="55" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="9" value="Shared RAM: ratings[], user_mean[], sim_matrix[], predictions[]" style="text;html=1;fontSize=8;fontColor=#333333;align=center;" vertex="1" parent="4">
          <mxGeometry x="20" y="138" width="430" height="22" as="geometry" />
        </mxCell>
        <mxCell id="9b" value="#pragma omp parallel for schedule(dynamic, 4)&lt;br&gt;for (u = start_u; u &lt; end_u; u++) { pearson_similarity(u, v); }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;fontFamily=Courier New;" vertex="1" parent="4">
          <mxGeometry x="20" y="168" width="430" height="45" as="geometry" />
        </mxCell>
        <mxCell id="9c" value="MPI_Allgatherv(&amp;sim_matrix[start_u*N], local_rows*N, MPI_FLOAT, sim_matrix, rcvcts, displs, MPI_FLOAT, MPI_COMM_WORLD)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=8;fontFamily=Courier New;" vertex="1" parent="4">
          <mxGeometry x="20" y="223" width="430" height="45" as="geometry" />
        </mxCell>
        <mxCell id="9d" value="OMP barrier (implicit) then MPI_Allgatherv from main thread — satisfies MPI_THREAD_FUNNELED" style="text;html=1;fontSize=8;fontColor=#d45f00;align=center;fontStyle=2;" vertex="1" parent="4">
          <mxGeometry x="20" y="275" width="430" height="25" as="geometry" />
        </mxCell>

        <!-- NODE 1 -->
        <mxCell id="14" value="Node 1 — MPI Rank 1&lt;br&gt;Users 500–999  |  Private RAM" style="swimlane;startSize=40;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d45f00;fontSize=10;fontStyle=1;" vertex="1" parent="3">
          <mxGeometry x="590" y="50" width="470" height="310" as="geometry" />
