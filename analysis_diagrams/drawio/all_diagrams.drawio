          <mxGeometry x="150" y="18" width="600" height="26" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="#pragma omp parallel for — one shared address space, work split across a team of threads" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="150" y="42" width="600" height="20" as="geometry" />
        </mxCell>
