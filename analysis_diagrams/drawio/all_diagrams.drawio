        <!-- Work range diagram -->
        <mxCell id="40" value="&lt;b&gt;Ceiling-Division Work Range Assignment:  chunk = (N_USERS + nthreads - 1) / nthreads&lt;/b&gt;" style="text;html=1;fontStyle=1;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="355" width="800" height="25" as="geometry" />
