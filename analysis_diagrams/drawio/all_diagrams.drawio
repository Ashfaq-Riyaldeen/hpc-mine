<mxfile host="app.diagrams.net" modified="2025-05-16T00:00:00.000Z" version="21.1.2">

<!-- ================================================================
     PAGE 1 — 5-Phase Algorithm Pipeline
     ================================================================ -->
  <diagram id="page1" name="1 - Algorithm Pipeline">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="5-Phase Algorithm Pipeline — Pearson Correlation Recommender System" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=16;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="170" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- Phase 1 -->
        <mxCell id="3" value="&lt;b&gt;Phase 1 — Data Generation&lt;/b&gt;&lt;br&gt;Complexity: O(N × M)  |  srand(SEED = 42) → identical data on every run&lt;br&gt;70% sparsity, 10% test-split, ratings ∈ {1, 2, 3, 4, 5}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="310" y="75" width="490" height="65" as="geometry" />
        </mxCell>

        <!-- Arrow P1→P2 -->
        <mxCell id="4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="3" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Phase 2 -->
        <mxCell id="5" value="&lt;b&gt;Phase 2 — User Mean Computation&lt;/b&gt;&lt;br&gt;Complexity: O(N × M)  |  μ_u = average of user u's known ratings&lt;br&gt;Required by Pearson formula to normalise individual rating scales" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="310" y="188" width="490" height="65" as="geometry" />
        </mxCell>

        <!-- Arrow P2→P3 -->
        <mxCell id="6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;" edge="1" source="5" target="7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Phase 3 BOTTLENECK -->
        <mxCell id="7" value="&lt;b&gt;⚡  Phase 3 — Pearson Similarity Matrix  ⚡&lt;/b&gt;&lt;br&gt;Complexity: O(N² × M)  |  N(N-1)/2 = 499,500 Pearson calls  |  ≈ 500M operations&lt;br&gt;sim(u,v) = Σ(R_ui − μ_u)(R_vi − μ_v) / [√Σ(R_ui−μ_u)² × √Σ(R_vi−μ_v)²]&lt;br&gt;&lt;b&gt;— DOMINANT BOTTLENECK (~97% of total runtime) —&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;arcSize=6;fontColor=#6b0014;" vertex="1" parent="1">
          <mxGeometry x="310" y="301" width="490" height="90" as="geometry" />
        </mxCell>

        <!-- Arrow P3→P4 -->
        <mxCell id="8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;" edge="1" source="7" target="9" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Phase 4 -->
        <mxCell id="9" value="&lt;b&gt;Phase 4 — Rating Predictions&lt;/b&gt;&lt;br&gt;Complexity: O(N² × M)  |  TOP_K = 20 best neighbours with positive similarity&lt;br&gt;pred(u,i) = μ_u + Σ_k[ sim(u,k) × (R_ki − μ_k) ] / Σ_k sim(u,k)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;arcSize=6;fontColor=#5c3d00;" vertex="1" parent="1">
          <mxGeometry x="310" y="439" width="490" height="78" as="geometry" />
        </mxCell>

        <!-- Arrow P4→P5 -->
        <mxCell id="10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;" edge="1" source="9" target="11" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Phase 5 -->
        <mxCell id="11" value="&lt;b&gt;Phase 5 — MAE Evaluation&lt;/b&gt;&lt;br&gt;Complexity: O(|T|)  |  MAE = (1/|T|) Σ |pred(u,i) − actual(u,i)|&lt;br&gt;Correctness check: all versions must match serial within ±0.001" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="310" y="565" width="490" height="65" as="geometry" />
        </mxCell>

        <!-- Right badges -->
        <mxCell id="20" value="Serial only&lt;br&gt;(RNG determinism required)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="835" y="93" width="165" height="38" as="geometry" />
        </mxCell>
        <mxCell id="20e" value="" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;dashed=1;strokeColor=#6c8ebf;" edge="1" source="3" target="20" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="21" value="&lt;b&gt;Parallelised by:&lt;/b&gt;&lt;br&gt;OpenMP | Pthreads | MPI | Hybrid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="835" y="205" width="165" height="38" as="geometry" />
        </mxCell>
        <mxCell id="21e" value="" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;dashed=1;strokeColor=#82b366;" edge="1" source="5" target="21" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="22" value="&lt;b&gt;Parallelised by:&lt;/b&gt;&lt;br&gt;OpenMP | Pthreads | MPI&lt;br&gt;CUDA (GPU) | Hybrid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="835" y="318" width="165" height="50" as="geometry" />
        </mxCell>
        <mxCell id="22e" value="" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;dashed=1;strokeColor=#b85450;" edge="1" source="7" target="22" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="23" value="&lt;b&gt;Parallelised by:&lt;/b&gt;&lt;br&gt;OpenMP | Pthreads | MPI&lt;br&gt;CUDA (GPU) | Hybrid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="835" y="452" width="165" height="50" as="geometry" />
        </mxCell>
        <mxCell id="23e" value="" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;dashed=1;strokeColor=#d6b656;" edge="1" source="9" target="23" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="24" value="Serial only&lt;br&gt;(fast, O(|T|) ≈ 30k entries)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="835" y="580" width="165" height="38" as="geometry" />
        </mxCell>
        <mxCell id="24e" value="" style="edgeStyle=elbowEdgeStyle;elbow=orthogonal;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;dashed=1;strokeColor=#6c8ebf;" edge="1" source="11" target="24" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Left info panels -->
        <mxCell id="30" value="&lt;b&gt;Problem Parameters&lt;/b&gt;&lt;br&gt;N_USERS = 1,000&lt;br&gt;N_ITEMS = 1,000&lt;br&gt;SEED    = 42&lt;br&gt;TOP_K   = 20&lt;br&gt;SPARSITY = 70%&lt;br&gt;TEST_RATIO = 10%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="55" y="280" width="145" height="120" as="geometry" />
        </mxCell>

        <mxCell id="31" value="&lt;b&gt;Performance Metrics&lt;/b&gt;&lt;br&gt;Speedup:  S(p) = T_serial / T_p&lt;br&gt;Efficiency: E(p) = S(p) / p&lt;br&gt;Amdahl limit: 1/f (f = serial %)&lt;br&gt;MAE tolerance: ±0.001" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontColor=#5c3d00;" vertex="1" parent="1">
          <mxGeometry x="55" y="440" width="185" height="90" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="40" value="&lt;b&gt;Legend&lt;/b&gt;" style="text;html=1;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="620" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="41" value="Serial only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="55" y="645" width="105" height="28" as="geometry" />
        </mxCell>
        <mxCell id="42" value="Parallelised" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="175" y="645" width="105" height="28" as="geometry" />
        </mxCell>
        <mxCell id="43" value="Bottleneck" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="295" y="645" width="105" height="28" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

<!-- ================================================================
     PAGE 2 — OpenMP Fork-Join Parallelism
     ================================================================ -->
  <diagram id="page2" name="2 - OpenMP">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="OpenMP — Shared-Memory Fork-Join Parallelism" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=16;fontColor=#1a9641;" vertex="1" parent="1">
          <mxGeometry x="200" y="15" width="650" height="35" as="geometry" />
        </mxCell>

        <!-- Subtitle -->
        <mxCell id="3" value="Key idea: Master thread FORKS worker threads at a parallel region. All threads share the same memory. At the closing brace, all threads JOIN back into one." style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="100" y="50" width="900" height="25" as="geometry" />
        </mxCell>

        <!-- Master thread (left segment) -->
        <mxCell id="4" value="&lt;b&gt;Master Thread&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a9641;strokeColor=#1a9641;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="100" width="130" height="35" as="geometry" />
        </mxCell>

        <!-- FORK marker -->
        <mxCell id="5" value="&lt;b&gt;FORK&lt;/b&gt;&lt;br&gt;#pragma omp parallel" style="shape=mxgraph.flowchart.start_2;whiteSpace=wrap;html=1;fillColor=#1a9641;strokeColor=#005723;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="175" y="85" width="80" height="60" as="geometry" />
        </mxCell>

        <!-- Thread 0 -->
        <mxCell id="10" value="&lt;b&gt;Thread 0&lt;/b&gt;  |  users 0 – 249" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a9641;strokeColor=#1a9641;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="85" width="620" height="38" as="geometry" />
        </mxCell>

        <!-- Thread 1 -->
        <mxCell id="11" value="&lt;b&gt;Thread 1&lt;/b&gt;  |  users 250 – 499" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2daa55;strokeColor=#1a9641;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="133" width="620" height="38" as="geometry" />
        </mxCell>

        <!-- Thread 2 -->
        <mxCell id="12" value="&lt;b&gt;Thread 2&lt;/b&gt;  |  users 500 – 749" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#52c270;strokeColor=#1a9641;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="181" width="620" height="38" as="geometry" />
        </mxCell>

        <!-- Thread 3 -->
        <mxCell id="13" value="&lt;b&gt;Thread 3&lt;/b&gt;  |  users 750 – 999" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#a0ddad;strokeColor=#1a9641;fontColor=#333333;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="229" width="620" height="38" as="geometry" />
        </mxCell>

        <!-- JOIN marker -->
        <mxCell id="14" value="&lt;b&gt;JOIN&lt;/b&gt;&lt;br&gt;(barrier)" style="shape=mxgraph.flowchart.start_2;whiteSpace=wrap;html=1;fillColor=#1a9641;strokeColor=#005723;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="915" y="85" width="80" height="60" as="geometry" />
        </mxCell>

        <!-- Master thread (right segment) -->
        <mxCell id="15" value="&lt;b&gt;Master Thread&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a9641;strokeColor=#1a9641;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1010" y="100" width="130" height="35" as="geometry" />
        </mxCell>

        <!-- Phase Labels above threads -->
        <mxCell id="16" value="Phase 3: Similarity  (schedule=dynamic,4)  — each thread pulls 4 rows at a time from queue when idle" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontStyle=1;fontColor=#1a9641;" vertex="1" parent="1">
          <mxGeometry x="280" y="64" width="620" height="22" as="geometry" />
        </mxCell>

        <!-- Implicit barrier note -->
        <mxCell id="17" value="Implicit barrier: all threads finish&lt;br&gt;before next phase starts" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="900" y="195" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Separator line -->
        <mxCell id="18" value="" style="endArrow=none;dashed=1;strokeColor=#888888;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry x="30" y="290" width="1100" height="10" as="geometry">
            <Array as="points">
              <mxPoint x="1130" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Why dynamic scheduling -->
        <mxCell id="19" value="&lt;b&gt;Why schedule(dynamic, 4)?&lt;/b&gt;&lt;br&gt;Inner loop size for outer iteration u = N - u - 1.&lt;br&gt;Thread 0 gets most work (u=0 → 999 Pearson calls), Thread 3 gets least (u=750 → 249 calls).&lt;br&gt;Static scheduling causes severe load imbalance. Dynamic lets idle threads pull new chunks." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="310" width="500" height="90" as="geometry" />
        </mxCell>

        <!-- Race-free proof -->
        <mxCell id="20" value="&lt;b&gt;Race-free SIM writes (no mutex needed)&lt;/b&gt;&lt;br&gt;Thread T owns outer-loop values u ∈ {chunk_T}.&lt;br&gt;It writes SIM(u,v) and SIM(v,u) for v &gt; u.&lt;br&gt;No other thread owns the same u, so no cell is&lt;br&gt;written by two threads simultaneously." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="310" width="380" height="90" as="geometry" />
        </mxCell>

        <!-- Phase 4 private buffer -->
        <mxCell id="21" value="&lt;b&gt;Phase 4 — Thread-Private Buffer&lt;/b&gt;&lt;br&gt;#pragma omp parallel { &lt;br&gt;  SimPair *nbrs = malloc(N_USERS * sizeof(SimPair)); ← each thread gets own buffer&lt;br&gt;  #pragma omp for schedule(dynamic, 2)&lt;br&gt;  for (u = 0..N_USERS) { ... use nbrs ... }&lt;br&gt;  free(nbrs);&lt;br&gt;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="420" width="500" height="120" as="geometry" />
        </mxCell>

        <!-- Phase 5 reduction -->
        <mxCell id="22" value="&lt;b&gt;Phase 5 — OpenMP Reduction&lt;/b&gt;&lt;br&gt;#pragma omp parallel for reduction(+:err)&lt;br&gt;&lt;br&gt;Each thread gets a PRIVATE copy of err (init to 0).&lt;br&gt;Threads accumulate in parallel — no locks.&lt;br&gt;At end, OpenMP sums all private copies → shared err." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="420" width="380" height="120" as="geometry" />
        </mxCell>

        <!-- Timing note -->
        <mxCell id="23" value="&lt;b&gt;Timing: omp_get_wtime()&lt;/b&gt;&lt;br&gt;NOT clock() — clock() sums CPU time across all threads&lt;br&gt;(4 threads × 1s = reports 4s, not 1s).&lt;br&gt;omp_get_wtime() measures actual wall-clock elapsed time." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="565" width="450" height="80" as="geometry" />
        </mxCell>

        <!-- Shared memory model -->
        <mxCell id="24" value="&lt;b&gt;Shared Memory Model&lt;/b&gt;&lt;br&gt;All threads share:  ratings[], user_mean[], sim_matrix[], predictions[]&lt;br&gt;Variables declared INSIDE loop body are automatically thread-private.&lt;br&gt;No inter-thread copying. Race-free because writes to disjoint indices." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="565" width="470" height="80" as="geometry" />
        </mxCell>

        <!-- Compile/run -->
        <mxCell id="25" value="&lt;b&gt;Compile:&lt;/b&gt;  gcc -O2 -Wall -fopenmp -o openmp_rec openmp/openmp_recommender.c -lm&lt;br&gt;&lt;b&gt;Run:&lt;/b&gt;  OMP_NUM_THREADS=4  ./openmp_rec 1000 1000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a9641;strokeColor=#005723;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="765" width="700" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

<!-- ================================================================
     PAGE 3 — Pthreads
     ================================================================ -->
  <diagram id="page3" name="3 - Pthreads">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Pthreads — Manual POSIX Thread Management" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=16;fontColor=#b8860b;" vertex="1" parent="1">
          <mxGeometry x="200" y="15" width="650" height="35" as="geometry" />
        </mxCell>

        <!-- Main Thread bar -->
        <mxCell id="3" value="MAIN THREAD (sequential)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b8860b;strokeColor=#7d5c00;fontColor=#ffffff;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="65" width="1100" height="30" as="geometry" />
        </mxCell>

        <!-- Phase sections background -->
        <mxCell id="4" value="PHASE 2: User Means" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="130" y="60" width="270" height="260" as="geometry" />
        </mxCell>
        <mxCell id="5" value="PHASE 3: Similarity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="430" y="60" width="300" height="260" as="geometry" />
        </mxCell>
        <mxCell id="6" value="PHASE 4: Predictions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="760" y="60" width="280" height="260" as="geometry" />
        </mxCell>

        <!-- PHASE 2 Threads -->
        <mxCell id="10" value="Thread 0  |  rows 0–249" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b8860b;strokeColor=#7d5c00;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="145" y="110" width="240" height="28" as="geometry" />
        </mxCell>
        <mxCell id="11" value="Thread 1  |  rows 250–499" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c99d30;strokeColor=#7d5c00;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="145" y="150" width="240" height="28" as="geometry" />
        </mxCell>
        <mxCell id="12" value="Thread 2  |  rows 500–749" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d9b558;strokeColor=#7d5c00;fontColor=#333333;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="145" y="190" width="240" height="28" as="geometry" />
        </mxCell>
        <mxCell id="13" value="Thread 3  |  rows 750–999" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#edcf85;strokeColor=#7d5c00;fontColor=#333333;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="145" y="230" width="240" height="28" as="geometry" />
        </mxCell>
        <mxCell id="14" value="pthread_join × 4  (barrier)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b8860b;strokeColor=#7d5c00;fontColor=#ffffff;fontSize=9;fontStyle=1;" vertex="1" parent="1">
