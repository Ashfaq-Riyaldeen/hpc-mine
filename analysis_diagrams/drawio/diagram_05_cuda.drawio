          <mxGeometry x="490" y="70" width="250" height="25" as="geometry" />
        </mxCell>
        <mxCell id="31" value="REGISTERS (per-thread) — &lt;1 cycle&lt;br&gt;Local scalars: num, den_u, den_v, co&lt;br&gt;Top-K arrays: top_sim[20], top_rat[20], top_mu[20]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7600a3;strokeColor=#4d007a;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="490" y="100" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="32" value="SHARED MEMORY (per-block) — ~1 cycle, 48KB&lt;br&gt;Not used in this project (embarrassingly parallel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9333b3;strokeColor=#7600a3;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="490" y="163" width="350" height="45" as="geometry" />
        </mxCell>
        <mxCell id="33" value="L1 / L2 CACHE — hardware managed, transparent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b366cc;strokeColor=#7600a3;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="490" y="216" width="350" height="35" as="geometry" />
        </mxCell>
        <mxCell id="34" value="GLOBAL MEMORY (GPU DRAM) — ~300–600 cycles, GBs&lt;br&gt;d_ratings, d_user_mean, d_sim, d_pred live here" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5b8e3;strokeColor=#7600a3;fontColor=#333333;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="490" y="259" width="350" height="48" as="geometry" />
        </mxCell>
        <mxCell id="35" value="HOST MEMORY (CPU RAM) — via PCIe ~12 GB/s&lt;br&gt;h_ratings, h_sim_matrix, h_predictions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8fa;strokeColor=#7600a3;fontColor=#333333;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="490" y="315" width="350" height="45" as="geometry" />
        </mxCell>
        <mxCell id="36" value="cudaMemcpy HostToDevice" style="text;html=1;fontSize=8;fontColor=#7600a3;align=center;" vertex="1" parent="1">
          <mxGeometry x="870" y="300" width="160" height="20" as="geometry" />
        </mxCell>
        <mxCell id="36a" value="" style="edgeStyle=orthogonalEdgeStyle;startArrow=none;endArrow=block;endFill=1;strokeColor=#7600a3;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry x="850" y="340" width="10" height="10" as="geometry">
            <Array as="points">
              <mxPoint x="860" y="355" />
              <mxPoint x="860" y="283" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="37" value="cudaMemcpy DeviceToHost" style="text;html=1;fontSize=8;fontColor=#7600a3;align=center;" vertex="1" parent="1">
          <mxGeometry x="870" y="200" width="160" height="20" as="geometry" />
        </mxCell>
        <mxCell id="40" value="&lt;b&gt;Three CUDA Kernels&lt;/b&gt;" style="text;html=1;fontStyle=1;fontSize=11;fontColor=#7600a3;" vertex="1" parent="1">
          <mxGeometry x="30" y="445" width="250" height="25" as="geometry" />
        </mxCell>
        <mxCell id="41" value="&lt;b&gt;kernel_user_means&lt;/b&gt;&lt;br&gt;Grid: 1D  (blocks × 256 threads)&lt;br&gt;1 thread = 1 user row&lt;br&gt;Scans N_ITEMS items per thread&lt;br&gt;Launch: &lt;&lt;&lt;(N+255)/256, 256&gt;&gt;&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#7600a3;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="475" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="42" value="&lt;b&gt;kernel_similarity&lt;/b&gt;&lt;br&gt;Grid: 2D  (⌈N/16⌉ × ⌈N/16⌉ blocks × 16×16)&lt;br&gt;1 thread = 1 (u,v) pair&lt;br&gt;Upper triangle only (if u&gt;v return early)&lt;br&gt;Writes SIM(u,v) AND SIM(v,u) — race-free&lt;br&gt;Launch: dim3 grid(⌈N/16⌉,⌈N/16⌉), dim3 block(16,16)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5b8e3;strokeColor=#7600a3;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="285" y="475" width="330" height="110" as="geometry" />
        </mxCell>
        <mxCell id="43" value="&lt;b&gt;kernel_predictions&lt;/b&gt;&lt;br&gt;Grid: 2D (users × items)&lt;br&gt;1 thread = 1 (user, item) pair&lt;br&gt;In-register min-heap TOP_K=20&lt;br&gt;(qsort unavailable in device code)&lt;br&gt;Arrays top_sim[20], top_rat[20],&lt;br&gt;top_mu[20] live in registers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c49fd8;strokeColor=#7600a3;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="630" y="475" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="44" value="&lt;b&gt;Timing with CUDA Events (not clock_gettime)&lt;/b&gt;&lt;br&gt;Kernel launches are ASYNCHRONOUS — CPU returns immediately.&lt;br&gt;cudaEventRecord() inserts a GPU-side timestamp in the command stream.&lt;br&gt;cudaEventSynchronize() waits for GPU to finish before reading elapsed time." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8fa;strokeColor=#7600a3;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="595" width="550" height="80" as="geometry" />
        </mxCell>
        <mxCell id="50" value="&lt;b&gt;Compile:&lt;/b&gt;  nvcc -O2 -arch=sm_75 -o cuda_rec cuda/cuda_recommender.cu -lm&lt;br&gt;&lt;b&gt;Run:&lt;/b&gt;  ./cuda_rec 1000 1000     (requires NVIDIA GPU + nvcc)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7600a3;strokeColor=#4d007a;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="765" width="700" height="38" as="geometry" />
        </mxCell>
      </root>
