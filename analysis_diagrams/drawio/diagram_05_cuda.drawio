        <!-- Blocks -->
        <mxCell id="b00" value="Block(0,0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7600a3;strokeColor=#4d007a;fontColor=#ffffff;fontSize=10;" vertex="1" parent="grid">
