        <!-- ── GRID container ── -->
        <mxCell id="grid" value="CUDA GRID — 63×63 blocks (⌈1000/16⌉²)" style="swimlane;startSize=28;whiteSpace=wrap;html=1;fillColor=#f3e8fa;strokeColor=#7600a3;fontSize=11;fontStyle=1;" vertex="1" parent="1">
