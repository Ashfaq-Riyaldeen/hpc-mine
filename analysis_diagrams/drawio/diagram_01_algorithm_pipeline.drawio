<mxfile host="app.diagrams.net" version="21.1.2">
  <diagram id="page1" name="Algorithm Pipeline">
    <mxGraphModel dx="1200" dy="700" grid="0" pageWidth="1100" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="ttl" value="Pearson Correlation Recommender — 5-Phase Algorithm Pipeline" style="text;html=1;align=center;fontStyle=1;fontSize=15;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="120" y="18" width="800" height="32" as="geometry" />
        </mxCell>

        <!-- Phases -->
        <mxCell id="p1" value="&lt;b&gt;Phase 1 — Data Generation&lt;/b&gt;&lt;br&gt;O(N×M) | SEED=42 | 70% sparsity | ratings ∈ {1–5}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="70" width="450" height="52" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Phase 2 — User Mean Computation&lt;/b&gt;&lt;br&gt;O(N×M) | μ_u = average of known ratings per user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="175" width="450" height="52" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;⚡ Phase 3 — Pearson Similarity Matrix ⚡&lt;/b&gt;&lt;br&gt;O(N²×M) | 499,500 pairs | ~97% of runtime | BOTTLENECK&lt;br&gt;sim(u,v) = Σ(R_ui−μ_u)(R_vi−μ_v) / [√Σ(R_ui−μ_u)² · √Σ(R_vi−μ_v)²]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=11;arcSize=8;fontColor=#6b0014;" vertex="1" parent="1">
          <mxGeometry x="300" y="285" width="450" height="72" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;Phase 4 — Rating Predictions&lt;/b&gt;&lt;br&gt;O(N²×M) | TOP-K=20 neighbours | weighted Pearson average" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="415" width="450" height="52" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="&lt;b&gt;Phase 5 — MAE Evaluation&lt;/b&gt;&lt;br&gt;O(|T|) | MAE = (1/|T|)Σ|pred−actual| | tolerance ±0.001" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="300" y="522" width="450" height="52" as="geometry" />
        </mxCell>

        <!-- Sequential flow arrows -->
        <mxCell id="a12" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a23" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a34" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2.5;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" source="p3" target="p4" parent="1">
