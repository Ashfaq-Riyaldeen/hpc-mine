            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="53b" value="MAE sum to Rank 0" style="text;html=1;fontSize=9;fontColor=#d6b656;align=center;" vertex="1" parent="1">
          <mxGeometry x="845" y="560" width="145" height="20" as="geometry" />
        </mxCell>
        <mxCell id="60" value="&lt;b&gt;Phase-by-Phase MPI Strategy&lt;/b&gt;" style="text;html=1;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="605" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="61" value="Phase 1: All ranks run srand(42) → identical data. No communication." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="630" width="520" height="28" as="geometry" />
        </mxCell>
        <mxCell id="62" value="Phase 2: Rank r computes mean[start..end], then MPI_Allgatherv assembles full mean[] on every rank." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="663" width="520" height="28" as="geometry" />
        </mxCell>
        <mxCell id="63" value="Phase 3: Rank r fills ALL columns for its rows. MPI_Allgatherv assembles full N×N sim_matrix on every rank." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="696" width="520" height="28" as="geometry" />
        </mxCell>
        <mxCell id="64" value="Phase 4: Each rank predicts only its users. No MPI needed (sim_matrix is already complete everywhere)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="729" width="520" height="28" as="geometry" />
        </mxCell>
        <mxCell id="65" value="Phase 5: Each rank accumulates local error. MPI_Reduce(MPI_SUM) sends total to Rank 0 for MAE." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="762" width="520" height="28" as="geometry" />
        </mxCell>
        <mxCell id="70" value="&lt;b&gt;Compile:&lt;/b&gt;  mpicc -O2 -Wall -o mpi_rec mpi/mpi_recommender.c -lm&lt;br&gt;&lt;b&gt;Run:&lt;/b&gt;  mpirun -np 4 ./mpi_rec 1000 1000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d7191c;strokeColor=#9e0000;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="570" y="762" width="470" height="38" as="geometry" />
        </mxCell>
