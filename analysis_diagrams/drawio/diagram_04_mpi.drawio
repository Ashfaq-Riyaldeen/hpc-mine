        <mxCell id="50" value="&lt;b&gt;MPI_Allgatherv&lt;/b&gt;&lt;br&gt;Each rank sends its slice.&lt;br&gt;Every rank receives the&lt;br&gt;FULL assembled array.&lt;br&gt;Used for:&lt;br&gt;• user_mean[]&lt;br&gt;• sim_matrix[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="850" y="140" width="160" height="165" as="geometry" />
        </mxCell>
        <mxCell id="51" value="&lt;b&gt;MPI_Reduce&lt;/b&gt;&lt;br&gt;Each rank contributes&lt;br&gt;partial MAE sum.&lt;br&gt;Rank 0 receives&lt;br&gt;global total.&lt;br&gt;op = MPI_SUM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="850" y="405" width="160" height="130" as="geometry" />
        </mxCell>
        <mxCell id="52" value="" style="startArrow=block;startFill=1;endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry x="850" y="200" width="10" height="10" as="geometry">
            <Array as="points">
              <mxPoint x="840" y="180" />
              <mxPoint x="840" y="395" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="53" value="" style="startArrow=none;endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry x="850" y="500" width="10" height="10" as="geometry">
            <Array as="points">
