        <mxCell id="50" value="&lt;b&gt;ThreadArgs Struct&lt;/b&gt;&lt;br&gt;typedef struct {&lt;br&gt;  int tid;      // 0-based thread index&lt;br&gt;  int nthreads; // total thread count&lt;br&gt;} ThreadArgs;&lt;br&gt;&lt;br&gt;Thread derives its [start, end) range&lt;br&gt;independently — no global state needed." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="455" width="320" height="150" as="geometry" />
        </mxCell>
        <mxCell id="51" value="&lt;b&gt;run_parallel() Harness&lt;/b&gt;&lt;br&gt;// Create all threads&lt;br&gt;for (t = 0; t &lt; N_THREADS; t++)&lt;br&gt;  pthread_create(&amp;threads[t], NULL, fn, &amp;args[t]);&lt;br&gt;&lt;br&gt;// Wait for ALL threads (= phase barrier)&lt;br&gt;for (t = 0; t &lt; N_THREADS; t++)&lt;br&gt;  pthread_join(threads[t], NULL);&lt;br&gt;&lt;br&gt;// pthread_join = BARRIER" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="370" y="455" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="52" value="&lt;b&gt;Thread-Private nbrs Buffer&lt;/b&gt;&lt;br&gt;void *thread_predictions(void *arg) {&lt;br&gt;  // Heap allocation per thread — NEVER shared&lt;br&gt;  SimPair *nbrs = malloc(N_USERS * sizeof(...));&lt;br&gt;  for (u = start; u &lt; end; u++) {&lt;br&gt;    // use nbrs for neighbour sorting&lt;br&gt;  }&lt;br&gt;  free(nbrs);&lt;br&gt;  return NULL;&lt;br&gt;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="750" y="455" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="60" value="&lt;b&gt;Compile:&lt;/b&gt;  gcc -O2 -Wall -o pthreads_rec pthreads/pthreads_recommender.c -lpthread -lm&lt;br&gt;&lt;b&gt;Run:&lt;/b&gt;  ./pthreads_rec 1000 1000 4     (args: N_USERS  N_ITEMS  N_THREADS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b8860b;strokeColor=#7d5c00;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="765" width="750" height="38" as="geometry" />
        </mxCell>
